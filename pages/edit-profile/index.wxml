<page-meta>
  <navigation-bar title="编辑资料" back="{{true}}" delta="2" color="black" background="#FFF"></navigation-bar>
</page-meta>

<scroll-view class="scrollarea" scroll-y>
  <view class="edit-container">
    <!-- 头像编辑区域 -->
    <view class="avatar-section">
      <view class="avatar-container" bindtap="onChooseAvatar">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="avatar-overlay">
          <text class="change-text">更换头像</text>
        </view>
      </view>
    </view>

    <!-- 基本信息表单 -->
    <view class="form-section">
      <view class="form-item">
        <text class="label">昵称</text>
        <input class="input" 
               value="{{userInfo.name}}" 
               placeholder="请输入昵称"
               bindinput="onNameInput"
               maxlength="20" />
      </view>

      <view class="form-item">
        <text class="label">性别</text>
        <view class="gender-selector">
          <view class="gender-option {{userInfo.gender === '♂' ? 'selected' : ''}}" 
                bindtap="onGenderSelect" 
                data-gender="♂">
            <text class="gender-icon">♂</text>
            <text class="gender-text">男</text>
          </view>
          <view class="gender-option {{userInfo.gender === '♀' ? 'selected' : ''}}" 
                bindtap="onGenderSelect" 
                data-gender="♀">
            <text class="gender-icon">♀</text>
            <text class="gender-text">女</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="label">个人简介</text>
        <textarea class="textarea" 
                  value="{{userInfo.bio}}" 
                  placeholder="介绍一下自己吧~"
                  bindinput="onBioInput"
                  maxlength="100"
                  auto-height />
        <view class="char-count">{{userInfo.bio.length}}/100</view>
      </view>
    </view>

    <!-- 保存按钮 -->
    <view class="save-section">
      <button class="save-btn" bindtap="onSave" disabled="{{!canSave}}">
        保存
      </button>
    </view>
  </view>
</scroll-view>

