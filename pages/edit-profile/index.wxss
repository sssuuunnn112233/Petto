page {
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.edit-container {
  padding: 20px;
}

/* 头像编辑区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 30px;
}

.avatar-container {
  position: relative;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  text-align: center;
  padding: 8px;
}

.change-text {
  font-size: 12px;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}

.form-item {
  margin-bottom: 24px;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 16px;
  font-weight: 500;
  color: #333;
  margin-bottom: 12px;
}

.input {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 16px;
  background: #fff;
}

.input:focus {
  border-color: #FFD700;
}

/* 性别选择器 */
.gender-selector {
  display: flex;
  gap: 16px;
}

.gender-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px;
  border: 2px solid #e0e0e0;
  border-radius: 12px;
  background: #fff;
  transition: all 0.3s ease;
}

.gender-option.selected {
  border-color: #FFD700;
  background: #FFF8DC;
}

.gender-icon {
  font-size: 24px;
  margin-bottom: 8px;
}

.gender-text {
  font-size: 14px;
  color: #666;
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 80px;
  padding: 12px 16px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 16px;
  background: #fff;
  resize: none;
}

.textarea:focus {
  border-color: #FFD700;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

/* 保存按钮区域 */
.save-section {
  padding: 0 20px;
}

.save-btn {
  width: 100%;
  height: 48px;
  background: #FFD700;
  color: #333;
  border: none;
  border-radius: 24px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn:disabled {
  background: #e0e0e0;
  color: #999;
}

.save-btn:not(:disabled):active {
  background: #FFC107;
}

