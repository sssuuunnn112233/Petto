/**index.wxss**/
page {
  height: 100vh;
  background: #FFF8DC; /* 温馨米色背景 */
}

.page {
  height: 100vh;
  background: #FFF8DC; /* 温馨米色背景 */
  position: relative;
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60px;
  background: rgba(255, 255, 255, 0.95); /* 半透明白色 */
  padding: 0 16px;
  padding-top: 44px;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  border-bottom: 1px solid rgba(139, 69, 19, 0.1); /* 淡棕色边框 */
  backdrop-filter: blur(10px);
  z-index: 100;
}

.header-left, .header-right {
  width: 50px;
  display: flex;
  align-items: center;
}

.header-right {
  justify-content: flex-end;
}

.search-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18px;
  background: rgba(245, 222, 179, 0.5); /* 半透明小麦色 */
  color: #8B4513; /* 棕色 */
  border: 1px solid rgba(139, 69, 19, 0.2);
}

.search-btn .icon {
  font-size: 18px;
  color: #8B4513; /* 棕色 */
}

.header-title {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
  color: #8B4513; /* 棕色 */
  flex-direction: column;
  gap: 2px;
}

.cloud-status {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12px;
  border: 1px solid #e0e0e0;
  backdrop-filter: blur(10px);
}

.cloud-status.online {
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.cloud-status.offline {
  background: rgba(158, 158, 158, 0.1);
  border-color: rgba(158, 158, 158, 0.3);
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  margin-right: 4px;
}

.cloud-status.online .status-dot {
  background: #4CAF50;
  box-shadow: 0 0 4px rgba(76, 175, 80, 0.5);
}

.cloud-status.offline .status-dot {
  background: #9E9E9E;
}

.status-text {
  font-size: 10px;
  color: #666;
  font-weight: 500;
}

.cloud-status.online .status-text {
  color: #4CAF50;
}

.cloud-status.offline .status-text {
  color: #9E9E9E;
}

/* 搜索栏 */
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(245, 222, 179, 0.5); /* 半透明小麦色 */
  border-radius: 20px;
  padding: 0 16px;
  margin: 0 8px;
  height: 36px;
  border: 1px solid rgba(139, 69, 19, 0.2);
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #8B4513; /* 棕色 */
  height: 100%;
}

.search-input::placeholder {
  color: #CD853F; /* 秘鲁色 */
}

.search-clear {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8px;
}

.search-clear .icon {
  font-size: 14px;
  color: #CD853F; /* 秘鲁色 */
}

/* 分类导航栏 */
.category-nav {
  background: rgba(255, 255, 255, 0.95); /* 半透明白色 */
  border-bottom: 1px solid rgba(139, 69, 19, 0.1);
  backdrop-filter: blur(10px);
  position: fixed;
  top: 104px; /* header高度 */
  left: 0;
  right: 0;
  z-index: 99;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.category-item {
  flex-shrink: 0;
  padding: 12px 16px;
  font-size: 14px;
  color: #A0522D; /* 深棕色 */
  position: relative;
  font-weight: 500;
}

.category-item.active {
  color: #D2691E; /* 巧克力色 */
  font-weight: 600;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 3px;
  background: linear-gradient(135deg, #D2691E, #CD853F);
  border-radius: 2px;
}

.category-more {
  flex-shrink: 0;
  padding: 12px 8px;
  color: #CD853F; /* 秘鲁色 */
  font-size: 12px;
}

.test-btn {
  flex-shrink: 0;
  padding: 8px 12px;
  margin-left: 8px;
  background: rgba(210, 105, 30, 0.1);
  border-radius: 12px;
  border: 1px solid rgba(210, 105, 30, 0.3);
}

.test-text {
  font-size: 11px;
  color: #D2691E;
  font-weight: 500;
}

/* 内容区域 */
.content-scroll {
  background: #FFF8DC; /* 温馨米色背景 */
  -webkit-overflow-scrolling: touch;
  position: absolute;
  top: 160px; /* header + category-nav 的高度 */
  left: 0;
  right: 0;
  bottom: 0;
}

/* 搜索结果提示 */
.search-result-tip {
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.9); /* 半透明白色 */
  margin: 8px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  box-shadow: 0 2px 8px rgba(139, 69, 19, 0.1);
  border: 1px solid rgba(139, 69, 19, 0.1);
}

.tip-text {
  font-size: 13px;
  color: #A0522D; /* 深棕色 */
}

.tip-keyword {
  font-size: 13px;
  color: #D2691E; /* 巧克力色 */
  font-weight: 600;
}

.content-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 8px;
  padding-bottom: 120px; /* 足够的底部间距，避免被tabBar遮挡 */
}

.post-item {
  background: rgba(255, 255, 255, 0.9); /* 半透明白色 */
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(139, 69, 19, 0.1);
  border: 1px solid rgba(139, 69, 19, 0.1);
  display: flex;
  flex-direction: column;
  height: 280px; /* 固定高度确保对齐 */
}

.post-content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.post-image {
  width: 100%;
  height: 180px; /* 固定图片高度 */
  background: linear-gradient(135deg, #F5DEB3 0%, #DEB887 100%); /* 小麦色渐变 */
  object-fit: cover; /* 改为cover确保填满 */
  flex-shrink: 0;
}

.post-info {
  padding: 8px 12px 12px;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.post-title {
  font-size: 14px;
  line-height: 1.4;
  color: #8B4513; /* 棕色 */
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2; /* 限制为2行 */
  overflow: hidden;
  font-weight: 500;
  flex: 1;
}

/* 不同游戏风格的背景色 - 温馨色调 */
.game-pokemon {
  background: linear-gradient(135deg, #F5DEB3 0%, #DEB887 100%);
}

.game-digimon {
  background: linear-gradient(135deg, #FFDAB9 0%, #F4A460 100%);
}

.game-yokai {
  background: linear-gradient(135deg, #E6E6FA 0%, #D8BFD8 100%);
}

.game-roco {
  background: linear-gradient(135deg, #E0F6FF 0%, #B0E0E6 100%);
}

.game-seer {
  background: linear-gradient(135deg, #F0F8FF 0%, #E6F3FF 100%);
}

.game-mole {
  background: linear-gradient(135deg, #F0FFF0 0%, #E0FFE0 100%);
}

.game-aobi {
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4E1 100%);
}

.game-dragon {
  background: linear-gradient(135deg, #FFF8DC 0%, #FFEBCD 100%);
}

.post-info {
  padding: 8px 12px 12px;
}

.post-title {
  font-size: 14px;
  line-height: 1.4;
  color: #8B4513; /* 棕色 */
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-weight: 500;
}

.post-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
}

.author-avatar {
  width: 24px;
  height: 24px;
  border-radius: 12px;
  background: #F5DEB3; /* 小麦色 */
  border: 1px solid rgba(139, 69, 19, 0.2);
}

.author-name {
  font-size: 12px;
  color: #A0522D; /* 深棕色 */
  max-width: 100px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.like-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2px 4px;
  gap: 2px;
}

.like-icon {
  font-size: 20px;
  transition: transform 0.2s;
  line-height: 1;
}

.like-count {
  font-size: 11px;
  color: #CD853F; /* 秘鲁色 */
  line-height: 1;
}

.like-container.liked .like-count {
  color: #D2691E; /* 巧克力色 */
  font-weight: 600;
}

.like-container:active .like-icon {
  transform: scale(1.2);
}

.like-container.liked .like-icon {
  animation: heartBeat 0.3s ease-in-out;
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); }
}

.load-more {
  text-align: center;
  padding: 20px;
  padding-bottom: 100px; /* 增加底部间距 */
  color: #CD853F; /* 秘鲁色 */
  font-size: 14px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
  padding-bottom: 100px; /* 增加底部间距 */
  min-height: 300px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: #CD853F; /* 秘鲁色 */
}

/* 悬浮发布按钮 */
.fab-button {
  position: fixed;
  right: 20px;
  bottom: 80px;
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background: linear-gradient(135deg, #D2691E, #CD853F); /* 棕色渐变 */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(210, 105, 30, 0.4);
  z-index: 999;
  transition: transform 0.2s, box-shadow 0.2s;
}

.fab-button:active {
  transform: scale(0.95);
  box-shadow: 0 2px 8px rgba(210, 105, 30, 0.3);
}

.fab-icon {
  font-size: 32px;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}