page {
  height: 100%;
}

.container {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  height: 100%;
  min-height: 100%;
  padding: 0 30rpx 160rpx 30rpx !important;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 120rpx) !important;
  gap: 20rpx;
}

.bg {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  opacity: 0.6;
  pointer-events: none;
}

.top-info {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 180rpx);
  left: 30rpx;
  right: 30rpx;
  display: flex;
  justify-content: flex-start;
  z-index: 1;
}

.pet-info {
  background: rgba(255,255,255,.9);
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,.1);
}

.pet-name-container {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pet-name {
  font-weight: 600;
  font-size: 30rpx;
}

.pet-age {
  color: #666;
  font-size: 26rpx;
}


.preview-area {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  transition: all 0.3s ease;
}

.drop-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(7, 193, 96, 0.9);
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.4);
  animation: pulse 1s infinite;
  pointer-events: none;
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50% { transform: translate(-50%, -50%) scale(1.05); }
}
.tabs {
  display: flex;
  gap: 12rpx;
  padding: 0;
  margin-bottom: 20rpx;
  margin-top: 100rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.tab-item {
  background: rgba(255,255,255,.95);
  border: 2rpx solid #e8e8e8;
  border-radius: 999rpx;
  padding: 14rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.06);
  margin-top: -20px;
}

.tab-item.active {
  border-color: #07c160;
  color: #07c160;
  background: #f0fff4;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,.15);
  transform: scale(1.05);
}

.pet-base {
  width: 600rpx;
  height: 600rpx;
}

/* 自定义宠物基础容器 */
.custom-pet-base {
  position: relative;
  width: 600rpx;
  height: 600rpx;
}

/* 宠物图层 */
.pet-layer {
  position: absolute;
  top: -40px;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  object-fit: contain;
  object-position: center center;
}

/* 所有锚点定位现在由 cat-renderer 组件统一管理 */

.pet-outfit {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  object-fit: contain;
  transform: translate(-50%, -50%);
  cursor: move;
  z-index: 10;
  transition: all 0.2s;
  border: 2rpx dashed transparent;
  border-radius: 12rpx;
  padding: 4rpx;
}

.pet-outfit:active {
  opacity: 0.8;
  border-color: rgba(255, 107, 107, 0.5);
  background: rgba(255, 107, 107, 0.1);
}


.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0rpx;
  margin-bottom: 500rpx;
  width: 100%;
  justify-items: center;
}

.grid-item {
  background: rgba(255,255,255,.9);
  border-radius: 16rpx;
  padding: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.08);
  text-align: center;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  height: 180rpx;
  width: 100%;
}

.grid-item image {
  width: 100%;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f4f4f4;
  display: block;
  object-fit: contain;
  padding: 8rpx;
}

.grid-item .title {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #333;
  height: 32rpx;
  line-height: 32rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  text-align: center;
}

.grid-item.worn {
  opacity: 0.6;
  position: relative;
}

.worn-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: #07c160;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  width: 80%;
}

.btn-save,
.btn-clear {
  flex: 1;
  height: 70rpx;
  line-height: 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-save {
  background: linear-gradient(135deg, #5c2616 0%, #38150f 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(151, 4, 4, 0.3);
}

.btn-clear {
  background: rgba(233, 102, 69, 0.95);
  color: rgb(255, 255, 255);
  border: 2rpx solid #e8e8e8;
}

.btn-save::after,
.btn-clear::after {
  border: none;
}

/* 拖拽预览层 */
.drag-preview {
  position: fixed;
  width: 130rpx;
  height: 130rpx;
  /* 使用和配件完全相同的样式 */
  transform: translate(-50%, -50%);
  padding: 4rpx; /* 和 pet-outfit 一致 */
  z-index: 9999;
  pointer-events: none;
  opacity: 0.85;
  animation: drag-float 0.3s ease;
}

.drag-preview image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.4));
}

@keyframes drag-float {
  from {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0;
  }
  to {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.85;
  }
}

/* 调试：拖拽中心点标记 */
.drag-center-mark {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: red;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
}

