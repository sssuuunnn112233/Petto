/* 点赞页面样式 */
@import "/styles/message-common.wxss";

.like-icon {
  font-size: 32rpx;
  margin-left: 16rpx;
  opacity: 0.8;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.like-content {
  flex: 1;
}

.like-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.like-action {
  font-size: 26rpx;
  color: #666;
}

.like-time {
  font-size: 24rpx;
  color: #999;
}

.like-icon {
  font-size: 32rpx;
}