/* 聊天详情页面样式 */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 自定义头部 */
.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 88rpx);
  background: white;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 20rpx 16rpx 20rpx;
  border-bottom: 1rpx solid #e5e5e5;
  z-index: 100;
}

.back-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  cursor: pointer;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-placeholder {
  width: 120rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  padding-top: calc(env(safe-area-inset-top) + 108rpx);
  padding-bottom: 120rpx;
}

.message-item {
  margin-bottom: 20rpx;
}

.system-message {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 10rpx;
}

.message-user .chat-message {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-other .chat-message {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.message-content {
  max-width: 70%;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-word;
}

.message-user .message-content {
  background: #007AFF;
  color: white;
}

.message-other .message-content {
  background: white;
  color: #333;
  border: 1rpx solid #e5e5e5;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 25rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn {
  background: #007AFF;
  color: white;
  border: none;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
}

.send-btn[disabled] {
  background: #ccc;
  color: #999;
}