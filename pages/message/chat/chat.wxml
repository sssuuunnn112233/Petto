<!--聊天详情页面-->
<page-meta>
  <navigation-bar title="聊天" back="{{true}}" color="black" background="#FFF" bind:back="onNavBack"></navigation-bar>
</page-meta>

<view class="chat-container">
  <!-- 自定义返回按钮 -->
  <view class="custom-header">
    <view class="back-button" bindtap="goBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <view class="header-title">聊天</view>
    <view class="header-placeholder"></view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y="{{true}}" scroll-into-view="msg-{{messages.length-1}}">
    <view wx:for="{{messages}}" wx:key="id" class="message-item message-{{item.type}}" id="msg-{{index}}">
      <view wx:if="{{item.type === 'system'}}" class="system-message">
        <text>{{item.content}}</text>
      </view>
      <view wx:else class="chat-message">
        <view class="message-content">{{item.content}}</view>
        <view class="message-time">{{item.time}}</view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <input 
      class="message-input" 
      placeholder="输入消息..." 
      value="{{inputValue}}" 
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button class="send-btn" bindtap="sendMessage" disabled="{{!inputValue}}">发送</button>
  </view>
</view>