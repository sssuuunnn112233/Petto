<!--评论页面-->
<view class="message-page-container">
  <!-- 自定义头部 -->
  <message-header title="评论和@" bind:back="onBack" />

  <view class="message-content-area">
    <!-- 下拉刷新提示 -->
    <view wx:if="{{refreshing}}" class="refresh-container">
      <text class="refresh-text">正在刷新...</text>
    </view>

    <!-- 空状态 -->
    <empty-state 
      wx:if="{{!loading && comments.length === 0}}"
      icon="💬"
      title="还没有收到评论"
      description="分享更多内容来获得互动吧"
      action-text="去发布内容"
      show-action="{{true}}"
      bind:action="onGoToPost"
    />

    <!-- 加载中骨架屏 -->
    <view wx:if="{{loading && comments.length === 0}}" class="message-list">
      <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skeleton-item">
        <view style="display: flex;">
          <view class="skeleton-avatar"></view>
          <view style="flex: 1; margin-left: 24rpx;">
            <view class="skeleton-line short"></view>
            <view class="skeleton-line long"></view>
            <view class="skeleton-line" style="width: 40%;"></view>
            <view class="skeleton-line" style="width: 120rpx; height: 60rpx; border-radius: 30rpx; margin-top: 16rpx;"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 评论列表 -->
    <view wx:if="{{comments.length > 0}}" class="message-list">
      <view 
        wx:for="{{comments}}" 
        wx:key="id" 
        class="comment-item fade-in"
      >
        <image 
          class="user-avatar" 
          src="{{item.avatar}}" 
          mode="aspectFill"
          data-item="{{item}}"
          bindtap="onViewDetail"
        />
        <view class="comment-content">
          <view class="comment-header">
            <text class="user-name">{{item.user}}</text>
            <text class="comment-time">{{item.time}}</text>
            <view wx:if="{{item.type === 'mention'}}" class="mention-badge">@</view>
          </view>
          <view class="comment-text">{{item.content}}</view>
          <view class="comment-post">来自: {{item.post}}</view>
          <view class="comment-actions">
            <button 
              class="message-btn {{item.replied ? 'message-btn-done' : 'message-btn-primary'}}" 
              data-id="{{item.id}}"
              bindtap="onReply"
            >
              {{item.replied ? '已回复' : '回复'}}
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loadingMore}}" class="loading-container">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 没有更多数据 -->
    <view wx:if="{{noMore && comments.length > 0}}" class="no-more-container">
      <text class="no-more-text">没有更多了</text>
    </view>
  </view>
</view>