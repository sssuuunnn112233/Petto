/* 群聊聊天页面样式 */
page {
  background: #FFF8DC; /* 温馨米色背景 */
}

.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF8DC;
}

/* 自定义头部 */
.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 88rpx);
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 20rpx 16rpx 20rpx;
  border-bottom: 1rpx solid rgba(139, 69, 19, 0.1);
  z-index: 100;
  backdrop-filter: blur(10px);
}

.back-button {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  cursor: pointer;
}

.back-icon {
  font-size: 36rpx;
  color: #8B4513;
  font-weight: bold;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.group-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #8B4513;
}

.member-count {
  font-size: 24rpx;
  color: #A0522D;
  margin-top: 4rpx;
}

.setting-button {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  cursor: pointer;
}

.setting-icon {
  font-size: 32rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  padding-top: calc(env(safe-area-inset-top) + 108rpx);
  padding-bottom: 140rpx;
}

.message-item {
  margin-bottom: 24rpx;
}

/* 系统消息 */
.system-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  color: #A0522D;
  font-size: 24rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  margin: 0 80rpx;
}

.system-time {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #CD853F;
}

/* 聊天消息 */
.chat-message {
  width: 100%;
}

.message-left {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.message-right {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  justify-content: flex-end;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(139, 69, 19, 0.2);
  flex-shrink: 0;
}

.message-content-wrapper {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-left .message-content-wrapper {
  align-items: flex-start;
}

.message-right .message-content-wrapper {
  align-items: flex-end;
}

.user-name {
  font-size: 24rpx;
  color: #A0522D;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.message-content {
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.4;
  word-break: break-word;
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.1);
}

.message-left .message-content {
  background: rgba(255, 255, 255, 0.9);
  color: #8B4513;
  border: 1rpx solid rgba(139, 69, 19, 0.1);
  border-top-left-radius: 8rpx;
}

.message-right .message-content {
  background: linear-gradient(135deg, #D2691E, #CD853F);
  color: white;
  border-top-right-radius: 8rpx;
}

.message-time {
  font-size: 22rpx;
  color: #CD853F;
  margin-top: 8rpx;
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(139, 69, 19, 0.1);
  display: flex;
  align-items: center;
  gap: 16rpx;
  backdrop-filter: blur(10px);
}

.input-tools {
  display: flex;
  gap: 16rpx;
}

.tool-icon {
  font-size: 32rpx;
  padding: 8rpx;
  cursor: pointer;
}

.message-input {
  flex: 1;
  background: rgba(245, 222, 179, 0.5);
  border-radius: 25rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(139, 69, 19, 0.2);
  color: #8B4513;
}

.message-input::placeholder {
  color: #CD853F;
}

.send-btn {
  background: linear-gradient(135deg, #D2691E, #CD853F);
  color: white;
  border: none;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.send-btn[disabled] {
  background: #DDD;
  color: #999;
}