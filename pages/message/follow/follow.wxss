/* 关注页面样式 */
@import "/styles/message-common.wxss";

.user-bio {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.4;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.follow-content {
  flex: 1;
}

.follow-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.follow-action {
  font-size: 26rpx;
  color: #666;
}

.follow-time {
  font-size: 24rpx;
  color: #999;
}

.follow-btn {
  background: #007AFF;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.follow-btn.followed {
  background: #f0f0f0;
  color: #666;
}