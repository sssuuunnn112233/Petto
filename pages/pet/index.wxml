<page-meta>
  <navigation-bar title="Petto" back="{{false}}" color="black" background="#FFF"></navigation-bar>
</page-meta>

<view class="container">

  <!-- 背景图层 -->
  <image class="bg" src="{{currentBackground}}" mode="aspectFill" />

  <!-- 顶部信息区 -->
  <view class="top-info">
    <view class="pet-info" bindtap="onPetInfoTap">
      <text class="pet-name">{{petName}}</text>
      <text class="pet-age">年龄: {{petAge}} 岁</text>
    </view>
    <view class="status-bar">
      <view class="status-item">
        <text class="status-label">❤️ 心情值</text>
        <view class="status-progress">
          <view class="progress-bar mood-bar" style="{{moodBarStyle}}"></view>
        </view>
        <text class="status-value">{{mood}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">🍗 饥饿值</text>
        <view class="status-progress">
          <view class="progress-bar hunger-bar" style="{{hungerBarStyle}}"></view>
        </view>
        <text class="status-value">{{hunger}}</text>
      </view>
    </view>
  </view>

  <!-- 顶部信息区下方的功能按钮 -->
  <view class="function-buttons">
    <button class="function-btn" size="mini" bindtap="onWardrobeClick">
      <text class="btn-icon">👔</text>
      <text class="btn-text">衣橱</text>
    </button>
    <button class="function-btn" size="mini" bindtap="onCustomizeClick"  style="position: relative; left: 138rpx; top: 1rpx">
      <text class="btn-icon">✨</text>
      <text class="btn-text">捏脸</text>
    </button>
    <button class="function-btn" size="mini" bindtap="showBackgroundSelector" >
      <text class="btn-icon">🖼️</text>
      <text class="btn-text">背景</text>
    </button>
  </view>

  <!-- 宠物区域 -->
  <view class="pet-area">
    <!-- 自定义宠物（使用新的渲染组件） -->
    <view wx:if="{{useCustomPet && petCustomization}}" class="custom-pet" bindtap="onPetTouch">
      <cat-renderer 
        id="catRenderer"
        cat-config="{{petCustomization}}" 
        size="pet"
        debug="{{false}}"
        bind:imageerror="onPetImageError"
      />
      
      <!-- 装扮配件 -->
      <block wx:for="{{wornOutfits}}" wx:key="id">
        <image 
          class="pet-outfit-layer" 
          src="{{item.src}}" 
          style="left: {{item.x}}rpx; top: {{item.y}}rpx;"
          mode="aspectFit" />
      </block>
    </view>
    
    <!-- 默认宠物（PNG 图片） -->
    <view wx:else class="default-pet-container" bindtap="onPetTouch">
      <image src="/assets/pet_idle.png" class="pet" />
      
      <!-- 装扮配件（默认宠物也可以穿装扮） -->
      <block wx:for="{{wornOutfits}}" wx:key="id">
        <image 
          class="pet-outfit-layer" 
          src="{{item.src}}" 
          style="left: {{item.x}}rpx; top: {{item.y}}rpx;"
          mode="aspectFit" />
      </block>
    </view>
    
    <!-- 宠物临时气泡 -->
    <view wx:if="{{showPetBubble}}" class="bubble pet-bubble">
      <text>{{petBubbleText}}</text>
    </view>
  </view>


  <!-- 按钮操作区 -->
  <view class="action-buttons">
    <button bindtap="feedPet">喂食</button>
    <button bindtap="playWithPet">陪玩</button>
  </view>

  <!-- 分隔线 -->
  


  <!-- 加载状态提示 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <text>加载中...</text>
    </view>
  </view>

  
  <!-- 语音对话悬浮按钮（位于对话框上方右侧） -->
  <view class="voice-button {{isRecording ? 'recording' : ''}} {{isPlaying ? 'playing' : ''}}" bindtap="onVoiceTap">
    <image class="voice-icon" src="/assets/icon/mic.svg" />
    <view wx:if="{{isRecording}}" class="voice-status recording-indicator">🎤 录音中...</view>
    <view wx:if="{{isPlaying}}" class="voice-status playing-indicator">🔊 播放中...</view>
  </view>

  <!-- 对话框 -->
  <view class="chat-box">
    <view class="input-area">
      <!-- 用户临时气泡（显示在输入框上方） -->
      <view wx:if="{{showUserBubble}}" class="bubble user-bubble">
        <text>{{userBubbleText}}</text>
      </view>
      <input placeholder="对Petto说点什么..." bindinput="onInputChange" bindconfirm="sendMessage" value="{{inputValue}}" disabled="{{isAIThinking}}" />
      <button bindtap="sendMessage" disabled="{{isAIThinking}}">{{isAIThinking ? '思考中...' : '发送'}}</button>
    </view>
  </view>

  <!-- 宠物信息设置悬浮窗 -->
  <view wx:if="{{showPetSettingsModal}}" class="modal-mask" catchtouchmove="true">
    <view class="modal-panel">
      <view class="modal-title">编辑宠物信息</view>
      <view class="modal-field">
        <text class="label">名称</text>
        <input class="field-input" placeholder="请输入宠物名称" value="{{tempPetName}}" bindinput="onPetNameInput" bindconfirm="onSettingsConfirm" />
      </view>
      <view class="modal-field">
        <text class="label">性别</text>
        <view class="gender-group">
          <view class="gender-item {{tempPetGender==='male'?'active':''}}" data-gender="male" bindtap="onGenderSelect">男孩</view>
          <view class="gender-item {{tempPetGender==='female'?'active':''}}" data-gender="female" bindtap="onGenderSelect">女孩</view>
        </view>
      </view>
      <view class="modal-field">
        <text class="label">语音回应</text>
        <view class="voice-response-toggle" bindtap="onVoiceResponseToggle">
          <text class="toggle-text">文字输入时也用语音回复</text>
          <view class="toggle-switch {{tempEnableVoiceResponse ? 'active' : ''}}">
            <view class="toggle-slider"></view>
          </view>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn cancel" bindtap="onSettingsCancel">取消</button>
        <button class="btn confirm" bindtap="onSettingsConfirm">保存</button>
      </view>
    </view>
  </view>

  <!-- 开发测试面板 -->
  <view wx:if="{{isDevelopmentMode}}" class="dev-test-panel">
    <!-- 测试面板切换按钮 -->
    <view class="test-toggle-btn" bindtap="toggleTestPanel">
      <text class="test-icon">🧪</text>
      <text class="test-text">{{showTestPanel ? '隐藏' : '测试'}}</text>
    </view>
    
    <!-- 测试功能面板 -->
    <view wx:if="{{showTestPanel}}" class="test-panel">
      <view class="test-title">🔧 开发测试工具</view>
      
      <view class="test-section">
        <text class="section-title">语音功能测试</text>
        <view class="test-buttons">
          <button class="test-btn" size="mini" bindtap="testMockVoiceRecognition">
            🎤 模拟识别
          </button>
          <button class="test-btn" size="mini" bindtap="testMockVoiceSynthesis">
            🔊 模拟合成
          </button>
          <button class="test-btn" size="mini" bindtap="testFullVoiceFlow">
            🔄 完整流程
          </button>
          <button class="test-btn" size="mini" bindtap="testRandomChat">
            💬 随机对话
          </button>
        </view>
      </view>
      
      <view class="test-section">
        <text class="section-title">状态测试</text>
        <view class="test-buttons">
          <button class="test-btn" size="mini" bindtap="testStatusChange">
            📊 随机状态
          </button>
          <button class="test-btn" size="mini" bindtap="resetStatus">
            🔄 重置状态
          </button>
        </view>
      </view>
      
      <view class="test-section">
        <text class="section-title">设置</text>
        <view class="test-buttons">
          <button class="test-btn {{enableVoiceResponse ? 'voice-on' : 'voice-off'}}" size="mini" bindtap="toggleVoiceResponse">
            {{enableVoiceResponse ? '🔊 语音开' : '🔇 语音关'}}
          </button>
          <button class="test-btn storage-clean" size="mini" bindtap="manualCleanupStorage">
            🧹 清理存储
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 背景选择器 -->
  <view wx:if="{{showBackgroundSelector}}" class="modal-mask" catchtouchmove="true">
    <view class="background-selector-panel">
      <view class="selector-header">
        <view class="selector-title">选择背景</view>
        <view class="close-btn" bindtap="hideBackgroundSelector">✕</view>
      </view>
      <view class="background-grid">
        <view 
          wx:for="{{backgroundImages}}" 
          wx:key="id"
          class="background-item {{currentBackground === item.path ? 'active' : ''}}"
          data-path="{{item.path}}"
          data-name="{{item.name}}"
          bindtap="onBackgroundSelect"
        >
          <image class="background-preview" src="{{item.path}}" mode="aspectFill" />
          <text class="background-name">{{item.name}}</text>
          <view wx:if="{{currentBackground === item.path}}" class="selected-badge">✓</view>
        </view>
      </view>
    </view>
  </view>

</view>


