/**pages/create-post/create-post.wxss**/
page {
  height: 100vh;
  background: #FFF8DC; /* 温馨米色背景 */
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF8DC; /* 温馨米色背景 */
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  height: 60px;
  background: #fff;
  padding: 0 16px;
  padding-top: 44px;
  border-bottom: 1px solid #f0f0f0;
  position: relative;
}

.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8px;
}

.back-btn .icon {
  font-size: 32px;
  color: #333;
  font-weight: 300;
}

.header-title {
  flex: 1;
  font-size: 17px;
  font-weight: 600;
  color: #333;
  text-align: center;
}

.publish-btn {
  width: 60px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.publish-text {
  font-size: 16px;
  color: #ff2442;
  font-weight: 500;
}

.publish-text.disabled {
  color: #ccc;
}

/* 内容区域 */
.content-scroll {
  flex: 1;
  background: #FFF8DC; /* 温馨米色背景 */
  height: 0; /* 使用 0 让 flex: 1 生效 */
  -webkit-overflow-scrolling: touch;
  overflow-y: auto;
}

/* 区块样式 */
.section {
  background: #fff;
  padding: 16px;
  margin-bottom: 8px;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

/* 媒体类型选择 */
.media-type-selector {
  display: flex;
  gap: 12px;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px;
  border: 2px solid #f0f0f0;
  border-radius: 8px;
  background: #fafafa;
}

.type-item.active {
  border-color: #ff2442;
  background: #fff5f5;
}

.type-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.type-text {
  font-size: 14px;
  color: #666;
}

.type-item.active .type-text {
  color: #ff2442;
  font-weight: 500;
}

/* 图片网格 */
.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.media-item {
  width: calc(33.333% - 6px);
  aspect-ratio: 1;
  position: relative;
  border-radius: 8px;
  overflow: hidden;
}

.media-preview {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
}

.add-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2px dashed #d0d0d0;
  background: #fafafa;
}

.add-icon {
  font-size: 32px;
  color: #999;
  margin-bottom: 4px;
}

.add-text {
  font-size: 12px;
  color: #999;
}

.delete-btn {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 14px;
  color: #fff;
  line-height: 1;
}

/* 视频容器 */
.video-container {
  width: 100%;
}

.video-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 8px;
  border: 2px dashed #d0d0d0;
}

.placeholder-icon {
  font-size: 48px;
  margin-bottom: 8px;
}

.placeholder-text {
  font-size: 14px;
  color: #999;
}

.video-preview {
  position: relative;
  width: 100%;
  border-radius: 8px;
  overflow: hidden;
}

.video-player {
  width: 100%;
  aspect-ratio: 16/9;
  background: #000;
}

.video-delete {
  top: 8px;
  right: 8px;
}

/* 标题输入 */
.title-input {
  width: 100%;
  padding: 12px;
  font-size: 16px;
  color: #333;
  background: #fafafa;
  border-radius: 8px;
  border: 1px solid #f0f0f0;
}

.title-input::placeholder {
  color: #999;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.category-item {
  padding: 8px 16px;
  font-size: 14px;
  color: #666;
  background: #fafafa;
  border-radius: 20px;
  border: 1px solid #f0f0f0;
}

.category-item.active {
  color: #ff2442;
  background: #fff5f5;
  border-color: #ff2442;
  font-weight: 500;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  position: relative;
  z-index: 1;
  padding-bottom: 4px;
}

.tag-item {
  padding: 8px 16px;
  font-size: 13px;
  color: #666;
  background: #fafafa;
  border-radius: 16px;
  border: 1px solid #f0f0f0;
  min-height: 36px;
  min-width: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  position: relative;
  z-index: 10;
  cursor: pointer;
  touch-action: manipulation;
  -webkit-user-select: none;
}

.tag-item.selected {
  color: #ff2442 !important;
  background: #fff5f5 !important;
  border-color: #ff2442 !important;
  border-width: 1.5px !important;
  font-weight: 600 !important;
}

.tag-item:active {
  transform: scale(0.95);
  background: #f0f0f0;
}

.tag-item.selected:active {
  background: #ffe5e8;
}

/* 底部占位 */
.bottom-placeholder {
  height: 80px;
}

/* 底部发布栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid #f0f0f0;
  z-index: 100;
}

.publish-button {
  width: 100%;
  height: 44px;
  background: #ff2442;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(255, 36, 66, 0.3);
}

.publish-button:active {
  background: #e01e3a;
  transform: scale(0.98);
}

.publish-button.disabled {
  background: #ccc;
  box-shadow: none;
}

.publish-button-text {
  font-size: 16px;
  color: #fff;
  font-weight: 600;
}

