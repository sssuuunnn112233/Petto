page {
  background: #E8DCC8;
  height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 顶部按钮 */
.header {
  display: flex;
  justify-content: space-between;
  padding: 40rpx 60rpx 20rpx;
}

.btn-back,
.btn-ok {
  background: #000;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin:-30px 70px 10px;
}

/* 猫咪预览 */
.preview {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  gap: 5rpx;
  margin-top: -10px;
}

.cat {
  position: relative;
  width: 560rpx;
  height: 560rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  overflow: hidden;
}

.layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  object-fit: contain;
  object-position: center center;
}

/* 所有锚点定位现在由 cat-renderer 组件统一管理 */

/* 分类标签 */
.tabs {
  flex: 0 0 auto;
  display: flex;
  justify-content: center;
  gap: 50rpx;
  padding: 25rpx 15rpx;
  flex-wrap: wrap;
}

.tab {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.tab.active {
  background: #FFE97F;
  transform: scale(1.1);
}

.tab-icon {
  width: 80rpx;
  height: 80rpx;
}

/* 选项网格 */
.options {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: min-content;
  gap: 20rpx;
  padding: 45rpx 35rpx;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  overflow-y: auto;
  align-content: start;
  min-height: 500rpx;
}

.option {
  width: 100%;
  min-height: 160rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 15rpx;
  transition: all 0.3s;
  box-sizing: border-box;
  gap: 8rpx;
  border: 2rpx solid transparent;
}

.option.selected {
  background: #FFE97F;
  transform: scale(1.05);
  border-color: #FFD700;
}

.option-img {
  width: 130rpx;
  height: 130rpx;
  flex-shrink: 0;
  display: block;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 10rpx;
}

.option-name {
  font-size: 22rpx;
  color: #333;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  font-weight: 500;
}

.option-text {
  font-size: 24rpx;
  color: #666;
}
