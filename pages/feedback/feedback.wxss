/* pages/feedback/feedback.wxss */
page {
  background-color: #FFF8DC;
  height: 100vh;
}

.container {
  height: 100vh;
  padding: 16px;
}

/* 返回按钮 */
.back-button-section {
  margin-bottom: 16px;
}

.back-button {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20px;
  border: 1px solid #FFE4B5;
  width: fit-content;
}

.back-icon {
  font-size: 18px;
  color: #8B4513;
  margin-right: 4px;
  font-weight: bold;
}

.back-text {
  font-size: 14px;
  color: #8B4513;
}

/* 云端状态指示器 */
.cloud-status-bar {
  display: flex;
  justify-content: center;
  padding: 8px;
  margin-bottom: 16px;
}

.cloud-status {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12px;
  border: 1px solid #e0e0e0;
  backdrop-filter: blur(10px);
}

.cloud-status.online {
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.cloud-status.offline {
  background: rgba(158, 158, 158, 0.1);
  border-color: rgba(158, 158, 158, 0.3);
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  margin-right: 6px;
}

.cloud-status.online .status-dot {
  background: #4CAF50;
  box-shadow: 0 0 4px rgba(76, 175, 80, 0.5);
}

.cloud-status.offline .status-dot {
  background: #9E9E9E;
}

.status-text {
  font-size: 11px;
  color: #666;
  font-weight: 500;
}

.cloud-status.online .status-text {
  color: #4CAF50;
}

.cloud-status.offline .status-text {
  color: #9E9E9E;
}

/* 通用区块样式 */
.section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4444;
  margin-left: 4px;
}

.optional {
  font-size: 12px;
  color: #999;
  font-weight: normal;
  margin-left: 8px;
}

/* 反馈类型选择 */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.type-item {
  padding: 16px;
  border: 2px solid #f0f0f0;
  border-radius: 12px;
  transition: all 0.3s ease;
}

.type-item.active {
  border-color: #8B4513;
  background: #FFF8DC;
}

.type-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.type-label {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

.type-radio {
  width: 20px;
  height: 20px;
  border: 2px solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-item.active .type-radio {
  border-color: #8B4513;
}

.radio-dot {
  width: 10px;
  height: 10px;
  background: #8B4513;
  border-radius: 50%;
}

.type-desc {
  font-size: 14px;
  color: #666;
  line-height: 1.4;
}

/* 输入框样式 */
.input-field {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 16px;
  background: #fafafa;
}

.input-field:focus {
  border-color: #8B4513;
  background: #fff;
}

.textarea-field {
  width: 100%;
  min-height: 120px;
  padding: 12px 16px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 16px;
  background: #fafafa;
  line-height: 1.5;
}

.textarea-field:focus {
  border-color: #8B4513;
  background: #fff;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: #999;
  margin-top: 8px;
}

/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.image-item {
  position: relative;
  width: 80px;
  height: 80px;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 8px;
  border: 1px solid #e0e0e0;
}

.delete-btn {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 20px;
  height: 20px;
  background: #ff4444;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: bold;
}

.add-image-btn {
  width: 80px;
  height: 80px;
  border: 2px dashed #ddd;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.add-text {
  font-size: 12px;
  color: #666;
}

/* 提交区域 */
.submit-section {
  margin-top: 24px;
  margin-bottom: 16px;
}

.submit-btn {
  width: 100%;
  padding: 16px;
  background: #8B4513;
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
}

.submit-btn.submitting {
  background: #ccc;
  opacity: 0.7;
}

.submit-btn:not(.submitting):active {
  background: #A0522D;
}

.history-link {
  text-align: center;
  padding: 12px;
}

.history-link text {
  color: #8B4513;
  font-size: 14px;
  text-decoration: underline;
}

/* 温馨提示 */
.tips-section {
  background: #F0F8FF;
  border-radius: 12px;
  padding: 16px;
  border: 1px solid #E6F3FF;
}

.tips-title {
  font-size: 16px;
  font-weight: 600;
  color: #4682B4;
  margin-bottom: 12px;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tips-content text {
  font-size: 14px;
  color: #666;
  line-height: 1.4;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 12px;
  }
  
  .section {
    padding: 12px;
  }
  
  .image-item, .add-image-btn {
    width: 70px;
    height: 70px;
  }
}