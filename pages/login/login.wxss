/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 30px;
  box-sizing: border-box;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  animation: float 6s ease-in-out infinite;
}

.circle-1 {
  width: 120px;
  height: 120px;
  top: 10%;
  left: -20px;
  animation-delay: 0s;
}

.circle-2 {
  width: 80px;
  height: 80px;
  top: 60%;
  right: -10px;
  animation-delay: 2s;
}

.circle-3 {
  width: 60px;
  height: 60px;
  top: 30%;
  right: 20%;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(180deg); }
}

/* 主要内容 */
.login-content {
  width: 100%;
  max-width: 320px;
  z-index: 1;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 60px;
}

.logo-icon {
  font-size: 80px;
  margin-bottom: 20px;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-10px); }
  60% { transform: translateY(-5px); }
}

.app-name {
  font-size: 36px;
  font-weight: bold;
  color: white;
  margin-bottom: 10px;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.app-slogan {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
}

/* 功能介绍 */
.features-section {
  display: flex;
  justify-content: space-between;
  margin-bottom: 50px;
  padding: 0 10px;
}

.feature-item {
  flex: 1;
  text-align: center;
  padding: 0 5px;
}

.feature-icon {
  font-size: 24px;
  margin-bottom: 8px;
}

.feature-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.2;
}

/* 登录区域 */
.login-section {
  width: 100%;
}

.wx-login-btn {
  width: 100%;
  height: 50px;
  background: linear-gradient(45deg, #1aad19, #2dc653);
  border-radius: 25px;
  border: none;
  box-shadow: 0 4px 15px rgba(26, 173, 25, 0.4);
  margin-bottom: 20px;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn:active {
  transform: translateY(2px);
  box-shadow: 0 2px 10px rgba(26, 173, 25, 0.4);
}

.wx-login-btn.loading {
  background: linear-gradient(45deg, #999, #bbb);
  box-shadow: 0 4px 15px rgba(153, 153, 153, 0.4);
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.wx-icon, .loading-icon {
  font-size: 20px;
  margin-right: 8px;
}

.loading-icon {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.btn-text {
  font-size: 16px;
  font-weight: 500;
  color: white;
}

/* 登录提示 */
.login-tips {
  text-align: center;
  margin-bottom: 30px;
}

.tip-text {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
}

.link-text {
  font-size: 12px;
  color: #ffd700;
  text-decoration: underline;
}

/* 其他选项 */
.other-options {
  display: flex;
  justify-content: center;
  align-items: center;
}

.guest-btn, .contact-btn {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  padding: 8px 12px;
}

.divider {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 10px;
}

/* 底部装饰 */
.bottom-decoration {
  position: absolute;
  bottom: 30px;
  right: 30px;
  z-index: 0;
}

.pet-silhouette {
  font-size: 40px;
  opacity: 0.3;
  animation: sway 3s ease-in-out infinite;
}

@keyframes sway {
  0%, 100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}

/* 响应式适配 */
@media (max-height: 600px) {
  .login-container {
    padding: 20px 30px;
  }
  
  .logo-section {
    margin-bottom: 40px;
  }
  
  .features-section {
    margin-bottom: 30px;
  }
  
  .logo-icon {
    font-size: 60px;
  }
  
  .app-name {
    font-size: 28px;
  }
}