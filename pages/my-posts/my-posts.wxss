/* pages/my-posts/my-posts.wxss */
page {
  background-color: #FFF8DC;
  height: 100vh;
}

.container {
  height: calc(100vh - 44px - env(safe-area-inset-top)); /* 减去导航栏高度和安全区域 */
  padding: 16px;
  padding-bottom: 80px; /* 为悬浮按钮留空间 */
}


/* 统计信息 */
.stats-section {
  margin-bottom: 16px;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.stats-item {
  text-align: center;
}

.stats-number {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.stats-label {
  font-size: 12px;
  color: #666;
}

/* 动态列表 */
.posts-section {
  flex: 1;
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.post-item {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.post-image-container {
  position: relative;
  height: 200px;
}

.post-image {
  width: 100%;
  height: 100%;
}

.post-overlay {
  position: absolute;
  top: 0;
  right: 0;
  padding: 12px;
}

.post-stats {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.post-likes, .post-collects {
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 4px 8px;
  border-radius: 12px;
  font-size: 12px;
  text-align: center;
}

.post-info {
  padding: 16px;
}

.post-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
  display: block;
  line-height: 1.4;
}

.post-content {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12px;
  display: block;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-time {
  font-size: 12px;
  color: #999;
}

.post-tags {
  display: flex;
  gap: 4px;
}

.post-tag {
  font-size: 12px;
  color: #8B4513;
  background: #FFF8DC;
  padding: 2px 6px;
  border-radius: 8px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  width: 120px;
  height: 120px;
  margin-bottom: 16px;
  opacity: 0.6;
}

.empty-text {
  display: block;
  font-size: 18px;
  color: #666;
  margin-bottom: 8px;
}

.empty-desc {
  display: block;
  font-size: 14px;
  color: #999;
  margin-bottom: 24px;
}

.create-btn {
  background: #8B4513;
  color: white;
  border: none;
  border-radius: 20px;
  padding: 12px 24px;
  font-size: 14px;
}

/* 加载状态 */
.loading-section {
  text-align: center;
  padding: 20px;
}

.loading-text {
  font-size: 14px;
  color: #999;
}

/* 没有更多 */
.no-more-section {
  text-align: center;
  padding: 20px;
}

.no-more-text {
  font-size: 12px;
  color: #ccc;
}

/* 悬浮创建按钮 */
.fab-button {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 56px;
  height: 56px;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
  z-index: 100;
}

.fab-icon {
  font-size: 24px;
  color: white;
  font-weight: bold;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 12px;
  }
  
  .post-image-container {
    height: 180px;
  }
  
  .post-info {
    padding: 12px;
  }
  
  .fab-button {
    bottom: 20px;
    right: 20px;
    width: 48px;
    height: 48px;
  }
  
  .fab-icon {
    font-size: 20px;
  }
}
/* 帖子操作按钮 */
.post-actions {
  padding: 12px 16px;
  border-top: 1px solid #f0f0f0;
  background: #fafafa;
}

.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  background: #F5DEB3;
  border-radius: 20px;
  color: #8B4513;
  font-size: 14px;
  border: 1px solid #DEB887;
}

.delete-icon {
  font-size: 14px;
  margin-right: 4px;
}

.delete-text {
  font-size: 12px;
  font-weight: 500;
}

.delete-button:active {
  background: #DEB887;
  transform: scale(0.95);
}

/* 帖子项目样式调整 */
.post-item {
  background: #fff;
  border-radius: 12px;
  margin-bottom: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.post-image-container {
  position: relative;
}

.post-info {
  padding: 16px;
}