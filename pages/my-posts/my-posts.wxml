<!-- pages/my-posts/my-posts.wxml -->
<page-meta>
  <navigation-bar title="我的动态" back="{{true}}" delta="2" color="black" background="#FFF8DC"></navigation-bar>
</page-meta>

<scroll-view 
  class="container" 
  scroll-y 
  refresher-enabled="{{true}}"
  refresher-triggered="{{refreshing}}"
  bindrefresherrefresh="onRefresh"
  bindscrolltolower="onScrollToLower"
>


  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-number">{{userPosts.length}}</text>
        <text class="stats-label">动态</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">{{totalLikes}}</text>
        <text class="stats-label">获赞</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">{{totalFavorites}}</text>
        <text class="stats-label">收藏</text>
      </view>
    </view>
  </view>

  <!-- 动态列表 -->
  <view class="posts-section">
    <view class="posts-list">
      <view 
        class="post-item" 
        wx:for="{{userPosts}}" 
        wx:key="id"
      >
        <!-- 帖子图片 -->
        <view class="post-image-container" bindtap="onPostTap" data-post="{{item}}">
          <image 
            class="post-image" 
            src="{{item.image}}" 
            mode="aspectFill"
            binderror="onImageError"
            data-post-id="{{item.postId || item.id}}"
          ></image>
          <view class="post-overlay">
            <view class="post-stats">
              <text class="post-likes">❤ {{item.likeCount || 0}}</text>
              <text class="post-collects">⭐ {{item.favoriteCount || 0}}</text>
            </view>
          </view>
        </view>
        
        <!-- 帖子信息 -->
        <view class="post-info" bindtap="onPostTap" data-post="{{item}}">
          <text class="post-title">{{item.title || '无标题'}}</text>
          <text class="post-content">{{item.content || ''}}</text>
          <view class="post-meta">
            <text class="post-time">{{item.timeText}}</text>
            <view class="post-tags" wx:if="{{item.tags && item.tags.length > 0}}">
              <text class="post-tag" wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 删除按钮 -->
        <view class="post-actions">
          <view class="delete-button" catchtap="onDeletePost" data-post="{{item}}">
            <text class="delete-icon">🗑️</text>
            <text class="delete-text">删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{userPosts.length === 0 && !loading}}">
      <image class="empty-icon" src="/images/empty-posts.svg"></image>
      <text class="empty-text">还没有发布动态</text>
      <text class="empty-desc">分享你和宠物的美好时光吧</text>
      <button class="create-btn" bindtap="onCreatePost">发布动态</button>
    </view>

    <!-- 加载状态 -->
    <view class="loading-section" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more-section" wx:if="{{!hasMore && userPosts.length > 0}}">
      <text class="no-more-text">没有更多动态了</text>
    </view>
  </view>

  <!-- 悬浮创建按钮 -->
  <view class="fab-button" bindtap="onCreatePost">
    <text class="fab-icon">+</text>
  </view>
</scroll-view>