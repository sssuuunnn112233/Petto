/* 消息页面通用样式 */

/* 页面容器 */
.message-page-container {
  background: #f5f5f5;
  min-height: 100vh;
}

/* 内容区域 */
.message-content-area {
  padding: 20rpx;
  padding-top: calc(env(safe-area-inset-top) + 160rpx);
  padding-bottom: 100rpx;
}

/* 列表容器 */
.message-list {
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

/* 列表项基础样式 */
.message-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s ease;
  position: relative;
}

.message-item:last-child {
  border-bottom: none;
}

.message-item:active {
  background-color: rgba(0,0,0,0.02);
}

/* 用户头像 */
.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  border: 2rpx solid #f0f0f0;
}

/* 内容区域 */
.message-item-content {
  flex: 1;
  min-width: 0;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.message-action {
  font-size: 26rpx;
  color: #666;
}

/* 时间显示 */
.message-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 按钮样式 */
.message-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
  min-width: 120rpx;
  text-align: center;
}

.message-btn:active {
  transform: scale(0.95);
}

/* 主要按钮 */
.message-btn-primary {
  background: linear-gradient(45deg, #7CD8B3, #34C38F);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(52, 195, 143, 0.3);
}

/* 次要按钮 */
.message-btn-secondary {
  background: #f0f0f0;
  color: #666;
}

/* 已操作状态按钮 */
.message-btn-done {
  background: #e8f5e8;
  color: #34C38F;
  border: 1rpx solid #34C38F;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 下拉刷新样式 */
.refresh-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.refresh-text {
  font-size: 26rpx;
  color: #666;
  margin-left: 12rpx;
}

/* 无更多数据提示 */
.no-more-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 骨架屏样式 */
.skeleton-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 4rpx;
  margin: 8rpx 0;
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-line.long {
  width: 80%;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}